{
  "version": 2,
  "builds": [
    {
      "src": "server/package.json",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["server/**"],
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/dist/index.js"
    },
    {
      "src": "/health",
      "dest": "/server/dist/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server/dist/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}