# Copy to .env next to docker-compose.yml (never commit .env).

# Named Cloudflare Tunnel only (recommended). Create in:
#   Zero Trust → Networks → Tunnels → Create tunnel → Docker → copy token
# Also add a Public hostname on that tunnel: HTTPS → http://localhost:8880
# (hostname e.g. kokoro.yourdomain.com — must be on a zone in this Cloudflare account)
CLOUDFLARE_TUNNEL_TOKEN=
