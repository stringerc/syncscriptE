# Copy to env.local (gitignored) — NEVER commit real values.
# US East (Ashburn) home region identifier:
#   OCI_REGION=us-ashburn-1

OCI_USER_OCID=ocid1.user.oc1..aaaaaaaaREPLACE_ME
OCI_TENANCY_OCID=ocid1.tenancy.oc1..aaaaaaaaREPLACE_ME
# Optional: Identity Domain OCID (SSO / IAM domains) — not required for classic API-key CLI auth
# OCI_DOMAIN_OCID=ocid1.domain.oc1..aaaaaaaaREPLACE_ME

OCI_FINGERPRINT=aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99
OCI_REGION=us-ashburn-1
# Absolute path to the *private* API key PEM on this machine:
OCI_KEY_FILE=/Users/YOU/.oci/oci_api_key.pem
