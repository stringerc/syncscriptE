# Copy to instance-launch.env (gitignored). Used by scripts/retry-launch-a1.sh
#
# Fill OCIDs from Oracle Console (Networking → subnet, Compute → images) or `oci` queries.
# Region must match your home region (e.g. Ashburn = us-ashburn-1).

COMPARTMENT_OCID=ocid1.compartment.oc1..aaaaaaaaREPLACE_ME

# Public subnet OCID (where the instance gets a public IP)
SUBNET_OCID=ocid1.subnet.oc1.iad.aaaaaaaaREPLACE_ME

# Ubuntu 24.04 Minimal or aarch64 image OCID for A1 (Console → Compute → images, or oci compute image list)
IMAGE_OCID=ocid1.image.oc1.iad.aaaaaaaaREPLACE_ME

# Space-separated availability domains to rotate (order: try each, then sleep, repeat).
# Get names: oci iam availability-domain list -c TENANCY_OCID
# Example Ashburn: three lines like: lWjI:US-ASHBURN-AD-1 lWjI:US-ASHBURN-AD-2 lWjI:US-ASHBURN-AD-3
AVAILABILITY_DOMAINS="REPLACE_AD_1 REPLACE_AD_2 REPLACE_AD_3"

DISPLAY_NAME=syncscript-a1-retry
# Full single-VM stack (Kokoro + OpenClaw + Hermes): use 4 OCPU / 24 GB within Always Free caps.
# Smaller (e.g. 1 OCPU / 6 GB) can help when ADs report out of capacity — resize later in Console or `oci compute instance update --shape-config`.
SHAPE_CONFIG_JSON='{"ocpus":4.0,"memoryInGBs":24}'

# Single-line public key file (only ONE key)
SSH_PUBLIC_KEY_FILE=/Users/YOU/.ssh/id_ed25519.pub

# Seconds between full cycles (after trying each AD once). Default 300 = 5 min.
RETRY_INTERVAL_SEC=300

# 0 = unlimited attempts until success (Ctrl+C to stop). Set e.g. 100 to stop after 100 full cycles.
MAX_CYCLES=0

# Optional: Telegram DM when launch succeeds (set BOTH; keep this file private — gitignored)
# Bot: @BotFather → /newbot → token. Chat ID: message the bot, then open
#   https://api.telegram.org/bot<TOKEN>/getUpdates  and read message.chat.id
# TELEGRAM_BOT_TOKEN=123456789:AA...
# TELEGRAM_CHAT_ID=123456789
# TELEGRAM_HOURLY_STATUS=1   # 0 = no hourly “still running” DM (default 1 when token + chat id set)
