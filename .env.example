# ============================================================================
# SyncScript Environment Variables
# Copy this to .env and fill in your values
# ============================================================================

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  AI Provider (abstraction layer — api/lib/ai-service.ts)               ║
# ╚══════════════════════════════════════════════════════════════════════════╝
# Primary provider: nvidia (FREE via build.nvidia.com — DeepSeek R1, Llama, etc.)
# Options: nvidia | moonshot | deepseek | openrouter | openai | groq
AI_PROVIDER=nvidia
NVIDIA_API_KEY=nvapi-your_nvidia_nim_key
# Fallback providers (auto-tried if primary fails)
MOONSHOT_API_KEY=your_moonshot_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
# OPENROUTER_API_KEY=your_openrouter_key
# OPENAI_API_KEY=your_openai_key
# GROQ_API_KEY=your_groq_key    ← RECOMMENDED for dev: free at console.groq.com, 3x faster voice responses

# Optional: scripts/verify-nexus-tools-live.ts Step 2 (runNexusToolLoop + GET /tasks)
# Supabase: uses SUPABASE_* or VITE_SUPABASE_* / NEXT_PUBLIC_*; if unset, same public defaults as the app.
# Auth (first match): session JWT, or same JWT as Engram Edge verify:
# NEXUS_LIVE_TEST_JWT=eyJ...
# ENGRAM_LIVE_USER_JWT=eyJ...
# NEXUS_LIVE_TEST_EMAIL=you@example.com
# NEXUS_LIVE_TEST_PASSWORD=...
# Or anonymous sign-in if enabled on the Supabase project (no extra env).
# Or one-off user: NEXUS_LIVE_TEST_BOOTSTRAP=1 with SUPABASE_SERVICE_ROLE_KEY (creates a user — use sparingly).
# Optional: Separate key for AI endpoint auth (falls back to PHONE_API_SECRET)
# AI_API_KEY=your_ai_api_key

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Supabase                                                              ║
# ╚══════════════════════════════════════════════════════════════════════════╝
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-side only (never expose to frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
# If set locally, `npm run verify:nexus-tools-live` can run Step 2 automatically (Admin createUser + sign-in → JWT).
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Engram agent registry (optional) — Edge bridge at /functions/v1/.../engram
# Set ENGRAM_BASE_URL + optional ENGRAM_UPSTREAM_TOKEN as Supabase Edge secrets (not in Vite).
VITE_ENGRAM_ENABLED=0

# Hermes executor — Edge secret HERMES_BASE_URL (not Vite). Enable client bridge + optional UI dock:
# VITE_HERMES_ENABLED=1
# VITE_HERMES_UI=1
# Stable bringup (see integrations/HERMES_STABLE_TUNNEL.md):
# HERMES_BASE_URL_TARGET=https://hermes.exec.example.com
# HERMES_NAMED_TUNNEL=syncscript-hermes
# HERMES_PUBLIC_BASE_URL=https://hermes.exec.example.com
# Live smoke (local): npm run verify:engram:edge-live — uses SUPABASE_URL from above when set; else public URL from scripts/engram-public-supabase-url.mjs (same as client fallback).
# ENGRAM_EDGE_LIVE_VERIFY=1          # fail if URL missing (strict)
# ENGRAM_REQUIRE_CONNECTED=1       # fail unless Edge reports Engram connected (needs Edge secrets set)
# ENGRAM_LIVE_ALLOW_NOT_DEPLOYED=1  # exit 0 if Engram route 404 (until supabase functions deploy)
# ENGRAM_LIVE_USER_JWT=            # optional real user JWT for GET /discover smoke (not anon)

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Twilio Phone Integration                                             ║
# ╚══════════════════════════════════════════════════════════════════════════╝
# Get these from https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_from_twilio_console
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Phone API Security                                                    ║
# ╚══════════════════════════════════════════════════════════════════════════╝
# Generate a random secret: openssl rand -hex 32
PHONE_API_SECRET=your_random_secret_here
# Same value on Vercel (serverless) AND Supabase Edge (secrets) — required for create_task / add_note during phone calls (POST .../phone/nexus-execute).
# NEXUS_PHONE_EDGE_SECRET=your_matching_random_secret

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  App URL                                                               ║
# ╚══════════════════════════════════════════════════════════════════════════╝
# Your deployment URL (auto-detected on Vercel via VERCEL_URL)
APP_URL=https://syncscript.app

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Frontend (prefix with VITE_ for Vite to expose to browser)           ║
# ╚══════════════════════════════════════════════════════════════════════════╝
VITE_PHONE_API_URL=/api/phone
VITE_PHONE_API_KEY=same_as_PHONE_API_SECRET_above

# Kokoro TTS — self-hosted voice on EC2, tunneled via Cloudflare
# REQUIRED on Vercel (Project → Settings → Environment Variables): without KOKORO_TTS_URL, POST /api/ai/tts returns 503 and landing voice is silent.
# Server-side (used by api/ai/tts.ts proxy — Vercel → Cloudflare → EC2)
KOKORO_TTS_URL=https://YOUR_TUNNEL.trycloudflare.com
# GET /api/ai/tts returns kokoroDirectOrigin (same URL) for browser direct Kokoro if the proxy fails — no OpenAI.
# Client-side direct Kokoro (local dev only). Do **not** set VITE_KOKORO_TTS_URL on Vercel production —
# the hostname is baked into JS; Quick Tunnels expire → net::ERR_NAME_NOT_RESOLVED forever.
# Production: set **KOKORO_TTS_URL** only (server `api/ai/tts` proxy). Update it when the tunnel changes.
# VITE_KOKORO_TTS_URL=https://YOUR_TUNNEL.trycloudflare.com
# Rare prod debug only: VITE_ALLOW_CLIENT_DIRECT_KOKORO=true

# Landing Nexus: default uses bundled MP3 for the first line (instant). Set to false to use Kokoro for greeting too.
# VITE_NEXUS_STATIC_MP3_GREETING=false

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Stripe Payments                                                       ║
# ╚══════════════════════════════════════════════════════════════════════════╝
VITE_STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Google OAuth & APIs                                                   ║
# ╚══════════════════════════════════════════════════════════════════════════╝
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_GOOGLE_PLACES_API_KEY=your_google_places_api_key

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Weather & Location                                                    ║
# ╚══════════════════════════════════════════════════════════════════════════╝
# Get from https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key
VITE_OPENWEATHER_API_KEY=your_openweathermap_api_key

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Twitter API v2 (automated growth tweets)                             ║
# ╚══════════════════════════════════════════════════════════════════════════╝
# Create app at https://developer.x.com/en/portal/dashboard
# Must have Read & Write permissions under "User authentication settings"
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_token_secret

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Email (Resend)                                                        ║
# ╚══════════════════════════════════════════════════════════════════════════╝
# Powers welcome emails, Nexus send_email tool, and drip campaigns
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Error Tracking (Sentry)                                               ║
# ╚══════════════════════════════════════════════════════════════════════════╝
VITE_SENTRY_DSN=https://xxxx@o12345.ingest.sentry.io/12345

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Vercel Cron Security                                                  ║
# ╚══════════════════════════════════════════════════════════════════════════╝
CRON_SECRET=your_cron_secret_here

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Wake-Up Call                                                          ║
# ╚══════════════════════════════════════════════════════════════════════════╝
WAKE_UP_PHONE_NUMBER=+1xxxxxxxxxx

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Optional: Integration Providers                                       ║
# ╚══════════════════════════════════════════════════════════════════════════╝
# VITE_INTEGRATION_PROVIDER=supabase
# VITE_MERGE_API_KEY=your_merge_api_key
