{
  "name": "SyncScript — Launch Ops",
  "meta": {
    "templateCredsSetupCompleted": false,
    "syncscript_recipe_id": "recipe-launch-ops",
    "syncscript_template_version": 1,
    "syncscript_doc": "Triggers when a SyncScript event lands. Verifies the HMAC signature, then branches: task.created → post Slack message, document.created → comment on GitHub issue. Replace the Slack channel + GitHub repo before activating."
  },
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "syncscript-launch-ops",
        "options": {
          "rawBody": true
        }
      },
      "id": "f4d3a1c0-1111-4111-8111-aaaaaaaaaaaa",
      "name": "SyncScript Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [240, 300],
      "webhookId": "syncscript-launch-ops"
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Verify the HMAC-SHA256 signature SyncScript adds via X-SyncScript-Signature.\n// The secret is shown EXACTLY ONCE when you create the webhook in\n// Settings → Integrations → Webhooks. Paste it as the n8n credential\n// 'SyncScript Webhook Secret' (Header Auth or env var SYNCSCRIPT_WEBHOOK_SECRET).\nconst crypto = require('crypto');\nconst secret = $env.SYNCSCRIPT_WEBHOOK_SECRET || '';\nconst rawBody = $input.first().binary?.data ? $input.first().binary.data.toString('utf8') : JSON.stringify($input.first().json || {});\nconst sigHeader = String($input.first().headers?.['x-syncscript-signature'] || $input.first().headers?.['X-SyncScript-Signature'] || '');\nconst expected = crypto.createHmac('sha256', secret).update(rawBody).digest('hex');\nif (!secret) {\n  throw new Error('Missing SYNCSCRIPT_WEBHOOK_SECRET env var in n8n');\n}\nconst sig = sigHeader.replace(/^sha256=/, '');\nif (!crypto.timingSafeEqual(Buffer.from(sig, 'hex'), Buffer.from(expected, 'hex'))) {\n  throw new Error('Invalid SyncScript signature');\n}\nreturn $input.first().json;"
      },
      "id": "f4d3a1c0-2222-4222-8222-bbbbbbbbbbbb",
      "name": "Verify HMAC",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
                "combinator": "and",
                "conditions": [
                  { "id": "r1", "leftValue": "={{ $json.event_type }}", "rightValue": "task.created", "operator": { "type": "string", "operation": "equals" } }
                ]
              },
              "renameOutput": true,
              "outputKey": "task.created"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
                "combinator": "and",
                "conditions": [
                  { "id": "r2", "leftValue": "={{ $json.event_type }}", "rightValue": "document.created", "operator": { "type": "string", "operation": "equals" } }
                ]
              },
              "renameOutput": true,
              "outputKey": "document.created"
            }
          ]
        }
      },
      "id": "f4d3a1c0-3333-4333-8333-cccccccccccc",
      "name": "Branch by Event",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [680, 300]
    },
    {
      "parameters": {
        "select": "channel",
        "channelId": "={{ $env.SLACK_CHANNEL_ID || '#launches' }}",
        "text": ":rocket: *Task created* — {{ $json.payload.title }}\n• Priority: {{ $json.payload.priority }}\n• Due: {{ $json.payload.dueAt || 'unscheduled' }}\n• Open: https://www.syncscript.app/tasks/{{ $json.entity_id }}"
      },
      "id": "f4d3a1c0-4444-4444-8444-dddddddddddd",
      "name": "Post to Slack",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [900, 240],
      "credentials": { "slackApi": { "id": "REPLACE_WITH_SLACK_CRED_ID", "name": "Slack OAuth2" } }
    },
    {
      "parameters": {
        "operation": "create",
        "owner": "={{ $env.GITHUB_OWNER || 'your-org' }}",
        "repository": "={{ $env.GITHUB_REPO || 'your-repo' }}",
        "title": "Doc: {{ $json.payload.title }}",
        "body": "Created in SyncScript: {{ $json.payload.title }}\n\nLink: https://www.syncscript.app/documents/{{ $json.entity_id }}"
      },
      "id": "f4d3a1c0-5555-4555-8555-eeeeeeeeeeee",
      "name": "Open GitHub Issue",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1,
      "position": [900, 360],
      "credentials": { "githubApi": { "id": "REPLACE_WITH_GITHUB_CRED_ID", "name": "GitHub OAuth2" } }
    }
  ],
  "connections": {
    "SyncScript Webhook": { "main": [[{ "node": "Verify HMAC", "type": "main", "index": 0 }]] },
    "Verify HMAC":        { "main": [[{ "node": "Branch by Event", "type": "main", "index": 0 }]] },
    "Branch by Event":    { "main": [
      [{ "node": "Post to Slack",      "type": "main", "index": 0 }],
      [{ "node": "Open GitHub Issue", "type": "main", "index": 0 }]
    ] }
  },
  "settings": { "executionOrder": "v1" },
  "active": false,
  "versionId": "1.0.0",
  "tags": ["syncscript", "launch-ops"]
}
