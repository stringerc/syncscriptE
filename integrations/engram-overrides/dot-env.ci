# Minimal .env for CI Docker Compose (engram_translator clone). Not for production.
PROJECT_NAME="Agent Translator Middleware"
API_STR="/api/v1"
BASE_URL="http://127.0.0.1:8000"
POSTGRES_SERVER=db
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=translator_db
DATABASE_URL=postgresql+asyncpg://admin:password@db:5432/translator_db
AUTH_JWT_SECRET=ci-verify-engram-swagger-docs-secret-key-32b
AUTH_JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
SECRET_KEY=ci-secret-key-for-engram-verify
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
RATE_LIMIT_ENABLED=false
SENTRY_DSN=
OPENAI_API_KEY=sk-ci-placeholder
HTTPS_ONLY=false
# Quiets docker-compose warnings when Grafana is defined but not started in minimal up
GRAFANA_SMTP_HOST=
GRAFANA_SMTP_USER=
GRAFANA_SMTP_PASSWORD=
