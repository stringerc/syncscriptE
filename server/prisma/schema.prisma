// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Authentication
  emailVerified         Boolean?
  emailVerifiedAt       DateTime?
  emailVerificationToken String?
  emailVerificationExpiry DateTime?
  passwordResetToken   String?
  passwordResetExpires  DateTime?

  // Profile
  timezone     String?
  energyLevel  Int?     @default(5) // 1-10 scale
  avatar       String?   // URL to avatar image
  dailyEnergy  EnergyLevel[]
  
  // Location
  currentLocation String? // Current city/location
  homeLocation    String? // Home city/location
  workLocation    String? // Work city/location
  
  // Integrations
  calendarIntegrations CalendarIntegration[]
  financialAccounts    FinancialAccount[]
  
  // Data
  tasks        Task[]
  events       Event[]
  conversations Conversation[]
  notifications Notification[]
  notificationPreferences NotificationPreferences?
  achievements Achievement[]
  streaks      Streak[]
  userStats    UserStats?
  badges       Badge[]
  points       Point[]
  
  // Energy Engine
  energyPoints       EnergyPoint[]
  dailyChallenges    DailyChallenge[]
  energyConversions  EnergyConversion[]
  energyEmblems      EnergyEmblem[]
  energyProfile      UserEnergyProfile?
  
  // Settings
  settings UserSettings?

  @@map("users")
}

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  
  // Notification preferences
  emailNotifications    Boolean @default(true)
  pushNotifications     Boolean @default(true)
  smsNotifications      Boolean @default(false)
  
  // AI preferences
  aiSchedulingEnabled   Boolean @default(true)
  aiBudgetAdviceEnabled Boolean @default(true)
  aiEnergyAdaptation    Boolean @default(true)
  
  // Privacy
  dataSharingEnabled    Boolean @default(false)
  
  // Work preferences
  workHoursStart        String  @default("09:00")
  workHoursEnd          String  @default("17:00")
  breakDuration         Int     @default(15) // minutes
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model EnergyLevel {
  id        String   @id @default(cuid())
  userId    String
  level     Int      // 1-10 scale
  date      DateTime @default(now())
  notes     String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("energy_levels")
}

model CalendarIntegration {
  id          String   @id @default(cuid())
  userId      String
  provider    String   // "google", "outlook", "apple"
  accessToken String
  refreshToken String?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("calendar_integrations")
}

model FinancialAccount {
  id          String   @id @default(cuid())
  userId      String
  plaidItemId String
  accountId   String
  accountName String
  accountType String   // "checking", "savings", "credit", etc.
  balance     Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("financial_accounts")
}

model Task {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  priority    String @default("MEDIUM")   // "LOW", "MEDIUM", "HIGH", "URGENT"
  status      String @default("PENDING") // "PENDING", "IN_PROGRESS", "COMPLETED", "CANCELLED", "DEFERRED"
  dueDate     DateTime?
  estimatedDuration Int? // minutes
  actualDuration    Int? // minutes
  energyRequired    Int? // 1-10 scale
  budgetImpact      Float? // cost in dollars
  
  // AI-generated fields
  aiGenerated       Boolean @default(false)
  extractedFrom     String? // conversation ID or source
  
  // Scheduling
  scheduledAt       DateTime?
  completedAt       DateTime?
  deletedAt         DateTime? // Soft delete timestamp
  
  // Additional fields
  notes             String?  // User notes for the task
  location          String?  // Location where task should be performed
  
  // Relationships
  tags              String?  // Store as comma-separated string
  subtasks          Subtask[]
  eventId           String?  // Link to event for preparation tasks
  event             Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model Subtask {
  id        String   @id @default(cuid())
  taskId    String
  title     String
  completed Boolean  @default(false)
  order     Int
  
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("subtasks")
}

model Event {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  isAllDay    Boolean  @default(false)
  
  // Calendar integration
  calendarEventId String? // External calendar event ID
  calendarProvider String? // "google", "outlook", "apple"
  
  // AI enhancements
  aiGenerated Boolean @default(false)
  budgetImpact Float? // estimated cost
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  preparationTasks Task[] // Tasks generated for this event

  @@map("events")
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  content   String
  source    String   // "chatgpt", "syncscript", "email", etc.
  extractedTasks String? // Store as comma-separated string of task IDs
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("conversations")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "TASK_REMINDER", "BUDGET_ALERT", "ENERGY_ADAPTATION", etc.
  title     String
  message   String
  isRead    Boolean  @default(false)
  priority  String   @default("medium") // low, medium, high, urgent
  actionUrl String?
  actionText String?
  metadata  String?  // Store as JSON string
  channels  String?  // JSON array of channels
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model NotificationPreferences {
  id     String @id @default(cuid())
  userId String @unique
  
  // Channel preferences
  channels String // JSON object with channel settings
  
  // Timing preferences
  timing String // JSON object with timing settings
  
  // Type-specific preferences
  types String // JSON object with type-specific settings
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "streak", "completion", "budget", "energy", "domain", etc.
  title       String
  description String
  points      Int      @default(0)
  unlockedAt  DateTime @default(now())
  
  // Enhanced criteria and progress tracking
  criteria    String?  // JSON string with exact criteria
  progress    Int      @default(0) // Current progress (0-100)
  target      Int      @default(100) // Target value for completion
  isUnlocked  Boolean  @default(false) // Whether achievement is unlocked
  rarity      String   @default("common") // "common", "rare", "epic", "legendary"
  category    String?  // "productivity", "wellness", "social", "learning", etc.
  domain      String?  // "body", "mind", "social", "order", "finance", "outdoors", "rest"
  icon        String?  // Icon name or emoji
  metadata    String?  // JSON string for additional data
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("achievements")
}

model Streak {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "daily_tasks", "budget_adherence", etc.
  count     Int      @default(0)
  lastDate  DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

model UserStats {
  id        String @id @default(cuid())
  userId    String @unique
  
  // Overall stats
  totalPoints      Int @default(0)
  currentLevel     Int @default(1)
  experiencePoints Int @default(0)
  
  // Task stats
  tasksCompleted   Int @default(0)
  tasksCreated     Int @default(0)
  totalTaskTime    Int @default(0) // minutes
  
  // Event stats
  eventsAttended   Int @default(0)
  eventsCreated    Int @default(0)
  
  // Streak stats
  longestStreak    Int @default(0)
  currentStreak    Int @default(0)
  
  // Achievement stats
  achievementsUnlocked Int @default(0)
  badgesEarned     Int @default(0)
  
  // Time-based stats
  lastActiveDate   DateTime @default(now())
  joinDate         DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}

model Badge {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "first_task", "streak_7", "budget_master", etc.
  title       String
  description String
  icon        String?  // Icon name or URL
  rarity      String   @default("common") // "common", "rare", "epic", "legendary"
  earnedAt    DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("badges")
}

model Point {
  id          String   @id @default(cuid())
  userId      String
  amount      Int      // Can be positive or negative
  source      String   // "task_completion", "streak_bonus", "achievement", etc.
  description String?
  metadata    String?  // JSON string for additional data
  earnedAt    DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("points")
}

// Energy Engine Models
model EnergyPoint {
  id          String   @id @default(cuid())
  userId      String
  amount      Int      // EP earned (always positive)
  source      String   // "task_completion", "challenge_completion", "achievement", "event_completion"
  domain      String?  // "body", "mind", "social", "order", "finance", "outdoors", "rest"
  description String?
  metadata    String?  // JSON string for additional data
  earnedAt    DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("energy_points")
}

model DailyChallenge {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  domain      String   // "body", "mind", "social", "order", "finance", "outdoors", "rest"
  type        String   // "core" or "stretch"
  target      String   // What needs to be completed
  epReward    Int      // EP to be awarded
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  date        DateTime @default(now()) // Date the challenge is for
  metadata    String?  // JSON string for additional data
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("daily_challenges")
}

model EnergyConversion {
  id            String   @id @default(cuid())
  userId        String
  epEarned      Int      // Total EP earned that day
  energyGained  Int      // Energy gained from conversion (0-100)
  conversionRate Float   // Rate used for conversion
  date          DateTime @default(now())
  metadata      String?  // JSON string for conversion details
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("energy_conversions")
}

model EnergyEmblem {
  id          String   @id @default(cuid())
  userId      String
  emblemType  String   // "bolt", "heart", "comet", "wave"
  isUnlocked  Boolean  @default(false)
  unlockedAt  DateTime?
  isActive    Boolean  @default(false)
  metadata    String?  // JSON string for emblem data
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("energy_emblems")
}

model UserEnergyProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  currentEnergy     Int      @default(50) // 0-100 scale
  energyLevel       Int      @default(5)  // 1-10 scale (legacy)
  domainWeights     String?  // JSON object with domain weights
  personalizationData String? // JSON object for personalization
  lastConversion    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_energy_profiles")
}

// Enums removed for SQLite compatibility - using String types instead
