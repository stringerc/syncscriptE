// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  googleId  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Authentication
  emailVerified         Boolean?
  emailVerifiedAt       DateTime?
  emailVerificationToken String?
  emailVerificationExpiry DateTime?
  passwordResetToken   String?
  passwordResetExpires  DateTime?

  // Profile
  timezone     String?
  energyLevel  Int?     @default(5) // 1-10 scale
  avatar       String?   // URL to avatar image
  dailyEnergy  EnergyLevel[]
  showHolidays Boolean? @default(true) // Whether to show holiday events
  lastEnergyResetLocalDate DateTime? // Last date energy was reset (in user's timezone)
  
  // Location
  currentLocation String? // Current city/location
  homeLocation    String? // Home city/location
  workLocation    String? // Work city/location
  
  // Integrations
  calendarIntegrations CalendarIntegration[]
  financialAccounts    FinancialAccount[]
  
  // Financial & Budgeting
  transactions          Transaction[]
  budgets               Budget[]
  savingsGoals          SavingsGoal[]
  budgetAlerts          BudgetAlert[]
  categorizationRules   CategorizationRule[]
  recurringTransactions RecurringTransaction[]
  budgetSnapshots       BudgetSnapshot[]
  spendingForecasts     SpendingForecast[]
  
  // Data
  tasks        Task[]
  events       Event[]
  conversations Conversation[]
  notifications Notification[]
  notificationPreferences NotificationPreferences?
  achievements Achievement[]
  streaks      Streak[]
  userStats    UserStats?
  badges       Badge[]
  points       Point[]
  resources    Resource[]
  
  // Energy Engine
  energyPoints       EnergyPoint[]
  dailyChallenges    DailyChallenge[]
  challengeSessions  ChallengeSession[]
  energyConversions  EnergyConversion[]
  energyEmblems      EnergyEmblem[]
  energyProfile      UserEnergyProfile?
  
  // Settings
  settings UserSettings?
  
  // Feature Flags
  featureFlags UserFeatureFlags?
  
  // Analytics & Audit
  analyticsEvents AnalyticsEvent[]
  auditLogs       AuditLog[]
  
  // Phase 2 - Scripts
  scripts             Script[]
  scriptApplications  ScriptApplication[]
  
  // Phase 3 - External Calendars
  externalCalendarAccounts ExternalCalendarAccount[]
  
  // Phase 4 - Friends & Social
  friendRequestsSent       Friendship[] @relation("Requester")
  friendRequestsReceived   Friendship[] @relation("Addressee")
  friendPrefs              FriendPrefs?
  privacySettings          PrivacySetting?
  
  // Phase 6 - ShareScript Collaboration
  ownedProjects            Project[] @relation("ProjectOwner")
  projectMemberships       ProjectMember[] @relation("ProjectMemberships")
  assignments              Assignment[] @relation("Assignments")
  projectResourcesAdded    ProjectResource[] @relation("ProjectResourcesAdded")
  
  // Phase 7 - Brief System
  briefPreferences         BriefPreferences?
  journalEntries           JournalEntry[]
  briefCards               BriefCard[]
  
  // User Scripts (My Scripts Gallery)
  userScripts              UserScript[]
  
  // Budget History
  budgetHistory            BudgetHistory[]
  
  // Export System
  exportJobs               ExportJob[]
  exportTemplates          ExportTemplate[]
  exportAnalytics          ExportAnalytics[]
  
  // Daily Energy Snapshots
  energyDailySnapshots     UserEnergyDailySnapshot[]

  @@map("users")
}

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  
  // Notification preferences
  emailNotifications    Boolean @default(true)
  pushNotifications     Boolean @default(true)
  smsNotifications      Boolean @default(false)
  
  // AI preferences
  aiSchedulingEnabled   Boolean @default(true)
  aiBudgetAdviceEnabled Boolean @default(true)
  aiEnergyAdaptation    Boolean @default(true)
  
  // Privacy
  dataSharingEnabled    Boolean @default(false)
  
  // Work preferences
  workHoursStart        String  @default("09:00")
  workHoursEnd          String  @default("17:00")
  breakDuration         Int     @default(15) // minutes
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model EnergyLevel {
  id        String   @id @default(cuid())
  userId    String
  level     Int      // 1-10 scale
  date      DateTime @default(now())
  notes     String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("energy_levels")
}

model CalendarIntegration {
  id          String   @id @default(cuid())
  userId      String
  provider    String   // "google", "outlook", "apple"
  accessToken String
  refreshToken String?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("calendar_integrations")
}

model FinancialAccount {
  id          String   @id @default(cuid())
  userId      String
  plaidItemId String
  accountId   String
  accountName String
  accountType String   // "checking", "savings", "credit", etc.
  balance     Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("financial_accounts")
}

// ============================================================
// ENHANCED BUDGETING MODELS
// ============================================================

model Transaction {
  id                String   @id @default(cuid())
  userId            String
  financialAccountId String?
  
  // Transaction Details
  amount            Float
  description       String
  date              DateTime
  pending           Boolean  @default(false)
  transactionId     String?  // Plaid transaction ID
  
  // Categorization
  category          String?  // Main category
  subcategory       String?  // Subcategory
  merchantName      String?  // Enriched merchant name
  confidence        Float?   // Categorization confidence 0-1
  
  // Custom Metadata
  tags              String?  // JSON array
  notes             String?
  isRecurring       Boolean  @default(false)
  recurrencePattern String?  // JSON object
  
  // Project/Event Linking
  linkedEventId     String?
  linkedProjectId   String?
  budgetCategoryId  String?
  
  // User Overrides
  userCategorized   Boolean  @default(false) // User manually set category
  userRuleId        String?  // If categorized by custom rule
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  financialAccount  FinancialAccount? @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)
  budgetCategory    BudgetCategory? @relation(fields: [budgetCategoryId], references: [id], onDelete: SetNull)
  
  @@index([userId, date])
  @@index([category])
  @@index([merchantName])
  @@map("transactions")
}

model Budget {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String?
  
  // Time Period
  period          String   @default("MONTHLY") // "WEEKLY", "MONTHLY", "ANNUAL"
  startDate       DateTime
  endDate         DateTime?
  
  // Budget Settings
  totalIncome     Float?   // Expected income for period
  totalBudget     Float    // Total budgeted amount
  rolloverEnabled Boolean  @default(false) // Roll unused funds to next period
  
  // Sharing & Collaboration
  isShared        Boolean  @default(false)
  sharedWith      String?  // JSON array of user IDs
  
  // Metadata
  isActive        Boolean  @default(true)
  isTemplate      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories      BudgetCategory[]
  alerts          BudgetAlert[]
  
  @@map("budgets")
}

model BudgetCategory {
  id              String   @id @default(cuid())
  budgetId        String?
  name            String
  description     String?
  icon            String?  // Emoji or icon name
  
  // Budget Amounts
  budgetedAmount  Float
  spentAmount     Float    @default(0)
  
  // Category Details
  parentCategory  String?  // For subcategories
  categoryType    String   @default("EXPENSE") // "EXPENSE", "INCOME", "SAVINGS"
  color           String?  // Hex color code
  
  // Project scoping for manual budgeting
  projectId       String? // optional scoping
  
  // Tracking
  order           Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  budget          Budget?  @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
  lineItems       BudgetLineItem[]
  eventItems      EventBudgetItem[]
  
  @@index([budgetId])
  @@index([projectId])
  @@map("budget_categories")
}

model SavingsGoal {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String?
  
  // Goal Details
  targetAmount    Float
  currentAmount   Float    @default(0)
  targetDate      DateTime?
  priority        String   @default("MEDIUM") // "LOW", "MEDIUM", "HIGH"
  
  // Contribution Settings
  monthlyContribution Float?
  autoAllocate    Boolean  @default(false)
  
  // Linked Budget
  linkedBudgetCategoryId String?
  
  // Progress Tracking
  milestones      String?  // JSON array of milestone amounts
  isCompleted     Boolean  @default(false)
  completedAt     DateTime?
  
  // Metadata
  icon            String?
  color           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("savings_goals")
}

model BudgetAlert {
  id              String   @id @default(cuid())
  budgetId        String
  userId          String
  
  // Alert Configuration
  alertType       String   // "OVERSPEND", "APPROACHING_LIMIT", "LOW_BALANCE", "UNUSUAL_SPENDING", "BILL_DUE"
  threshold       Float?   // Percentage or amount
  categoryName    String?  // Specific category or null for overall
  
  // Alert Status
  isActive        Boolean  @default(true)
  lastTriggered   DateTime?
  triggerCount    Int      @default(0)
  
  // Notification Channels
  notifyEmail     Boolean  @default(true)
  notifyPush      Boolean  @default(true)
  notifyInApp     Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  budget          Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, isActive])
  @@map("budget_alerts")
}

model CategorizationRule {
  id              String   @id @default(cuid())
  userId          String
  
  // Rule Conditions
  matchType       String   // "MERCHANT", "DESCRIPTION", "AMOUNT_RANGE", "KEYWORD"
  matchValue      String   // What to match
  matchOperator   String   @default("CONTAINS") // "CONTAINS", "EQUALS", "STARTS_WITH", "REGEX"
  
  // Action
  assignCategory  String
  assignSubcategory String?
  priority        Int      @default(0) // Higher priority rules execute first
  
  // Metadata
  isActive        Boolean  @default(true)
  timesApplied    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, isActive])
  @@map("categorization_rules")
}

model RecurringTransaction {
  id              String   @id @default(cuid())
  userId          String
  
  // Transaction Pattern
  merchantName    String
  category        String
  averageAmount   Float
  frequency       String   // "WEEKLY", "BIWEEKLY", "MONTHLY", "QUARTERLY", "ANNUAL"
  
  // Detection Metadata
  firstSeen       DateTime
  lastSeen        DateTime
  occurrenceCount Int      @default(1)
  confidence      Float    // 0-1, how confident this is recurring
  
  // Next Expected
  nextExpectedDate DateTime?
  nextExpectedAmount Float?
  
  // Reminder Settings
  reminderEnabled Boolean  @default(false)
  reminderDaysBefore Int   @default(3)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("recurring_transactions")
}

model BudgetSnapshot {
  id              String   @id @default(cuid())
  userId          String
  budgetId        String
  
  // Snapshot Data
  snapshotDate    DateTime
  periodStart     DateTime
  periodEnd       DateTime
  
  // Financial Summary
  totalIncome     Float
  totalExpenses   Float
  totalSavings    Float
  netCashflow     Float
  
  // Category Breakdown (JSON)
  categoryData    String   // JSON object with category-wise spending
  
  // Comparison
  vsLastPeriod    Float?   // Percentage change
  vsBudget        Float?   // Percentage of budget used
  
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, snapshotDate])
  @@map("budget_snapshots")
}

model SpendingForecast {
  id              String   @id @default(cuid())
  userId          String
  budgetId        String
  
  // Forecast Details
  forecastDate    DateTime // Date this forecast is for
  generatedAt     DateTime @default(now())
  
  // Projected Amounts
  projectedSpending Float
  projectedIncome   Float
  projectedSavings  Float
  
  // Category Projections (JSON)
  categoryForecasts String // JSON object
  
  // Confidence & Alerts
  confidence      Float    // 0-1
  alerts          String?  // JSON array of alert messages
  
  // AI Insights
  aiInsights      String?  // JSON object with recommendations
  
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, forecastDate])
  @@map("spending_forecasts")
}

// ============================================================
// MANUAL BUDGETING SYSTEM MODELS
// ============================================================

model BudgetEnvelope {
  id            String   @id @default(cuid())
  eventId       String   @unique
  currency      String   @default("USD")
  capCents      Int?     // optional event budget cap
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventItems    EventBudgetItem[]
  
  @@map("budget_envelopes")
}

model TaskBudget {
  id              String   @id @default(cuid())
  taskId          String   @unique
  mode            String   // 'total' | 'lines'
  taxCents        Int      @default(0)
  shippingCents   Int      @default(0)
  estimatedCents  Int      @default(0) // Quick Total only
  actualCents     Int?     // set when user records actual
  includeInEvent  Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  lineItems       BudgetLineItem[]
  history         BudgetHistory[]
  
  @@map("task_budgets")
}

model BudgetHistory {
  id              String   @id @default(cuid())
  taskBudgetId    String
  changeType      String   // 'created', 'updated', 'line_item_added', 'line_item_updated', 'line_item_deleted', 'estimated_changed', 'actual_changed'
  oldValue        String?  // Previous state (for updates) - JSON string
  newValue        String?  // New state - JSON string
  changeReason    String?  // Optional reason for the change
  userId          String   // Who made the change
  createdAt       DateTime @default(now())
  
  taskBudget      TaskBudget @relation(fields: [taskBudgetId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([taskBudgetId, createdAt])
  @@map("budget_history")
}

model BudgetLineItem {
  id              String   @id @default(cuid())
  taskBudgetId    String
  name            String
  url             String?
  qty             Int      @default(1)
  unitPriceCents  Int      @default(0)
  categoryId      String?
  notes           String?
  isActual        Boolean  @default(false) // when marking actual at row-level (optional)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  taskBudget      TaskBudget @relation(fields: [taskBudgetId], references: [id], onDelete: Cascade)
  category        BudgetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  
  @@index([taskBudgetId])
  @@map("budget_line_items")
}

model EventBudgetItem {
  id              String   @id @default(cuid())
  eventId         String
  name            String
  url             String?
  estimatedCents  Int      @default(0)
  actualCents     Int?
  categoryId      String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  envelope        BudgetEnvelope @relation(fields: [eventId], references: [eventId], onDelete: Cascade)
  category        BudgetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  
  @@index([eventId])
  @@map("event_budget_items")
}

model Task {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  priority    String @default("MEDIUM")   // "LOW", "MEDIUM", "HIGH", "URGENT"
  status      String @default("PENDING") // "PENDING", "IN_PROGRESS", "COMPLETED", "CANCELLED", "DEFERRED"
  dueDate     DateTime?
  estimatedDuration Int? // minutes
  actualDuration    Int? // minutes
  energyRequired    Int? // 1-10 scale
  budgetImpact      Float? // cost in dollars
  
  // AI-generated fields
  aiGenerated       Boolean @default(false)
  extractedFrom     String? // conversation ID or source
  
  // Scheduling
  scheduledAt       DateTime?
  completedAt       DateTime?
  deletedAt         DateTime? // Soft delete timestamp
  
  // Scheduling Constraints (Phase 1)
  durationMin       Int? // Duration in minutes (alias for estimatedDuration)
  dependencies      String? // JSON array of task IDs this depends on
  storeHours        String? // JSON: { start: "09:00", end: "17:00", days: [1,2,3,4,5] }
  
  // Priority Hierarchy (Phase 2)
  isCritical        Boolean @default(false) // On critical path
  slackMin          Int? // Available slack in minutes
  lockedPriority    Boolean @default(false) // Manual override prevents auto-recompute
  
  // Additional fields
  notes             String?  // User notes for the task
  location          String?  // Location where task should be performed
  type              String?  // Task type: "PREPARATION", "FOLLOW_UP", etc.
  
  // Relationships
  tags              String?  // Store as comma-separated string
  subtasks          Subtask[]
  eventId           String?  // Link to event for preparation tasks
  event             Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  resourceSet       ResourceSet? // Optional resource set for this task
  taskBudget        TaskBudget? // Manual budgeting for this task
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model Subtask {
  id        String   @id @default(cuid())
  taskId    String
  title     String
  completed Boolean  @default(false)
  order     Int
  
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("subtasks")
}

model Event {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  isAllDay    Boolean  @default(false)
  
  // Calendar integration
  calendarEventId String? // External calendar event ID
  calendarProvider String? // "google", "outlook", "apple"
  
  // AI enhancements
  aiGenerated Boolean @default(false)
  budgetImpact Float? // estimated cost
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Scheduling Constraints (Phase 1)
  projectedFinish DateTime? // When all tasks are projected to complete
  bufferMinutes   Int? // Buffer time before event starts
  hasConflicts    Boolean @default(false) // Flag for quick conflict detection
  
  // Pinned Events (Phase 2)
  isPinned        Boolean @default(false)
  pinOrder        Int? // Order in pinned list (1-5)
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  preparationTasks Task[] // Tasks generated for this event
  resourceSet ResourceSet? // Optional resource set for this event
  budgetEnvelope BudgetEnvelope? // Manual budgeting envelope for this event
  budgetItems EventBudgetItem[] // Event-level budget items

  @@map("events")
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  content   String
  source    String   // "chatgpt", "syncscript", "email", etc.
  extractedTasks String? // Store as comma-separated string of task IDs
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("conversations")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "TASK_REMINDER", "BUDGET_ALERT", "ENERGY_ADAPTATION", etc.
  title     String
  message   String
  isRead    Boolean  @default(false)
  priority  String   @default("medium") // low, medium, high, urgent
  actionUrl String?
  actionText String?
  metadata  String?  // Store as JSON string
  channels  String?  // JSON array of channels
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model NotificationPreferences {
  id     String @id @default(cuid())
  userId String @unique
  
  // Channel preferences
  channels String // JSON object with channel settings
  
  // Timing preferences
  timing String // JSON object with timing settings
  
  // Type-specific preferences
  types String // JSON object with type-specific settings
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "streak", "completion", "budget", "energy", "domain", etc.
  title       String
  description String
  points      Int      @default(0)
  unlockedAt  DateTime @default(now())
  
  // Enhanced criteria and progress tracking
  criteria    String?  // JSON string with exact criteria
  progress    Int      @default(0) // Current progress (0-100)
  target      Int      @default(100) // Target value for completion
  isUnlocked  Boolean  @default(false) // Whether achievement is unlocked
  rarity      String   @default("common") // "common", "rare", "epic", "legendary"
  category    String?  // "productivity", "wellness", "social", "learning", etc.
  domain      String?  // "body", "mind", "social", "order", "finance", "outdoors", "rest"
  icon        String?  // Icon name or emoji
  metadata    String?  // JSON string for additional data
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("achievements")
}

model Streak {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "daily_tasks", "budget_adherence", etc.
  count     Int      @default(0)
  lastDate  DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

model UserStats {
  id        String @id @default(cuid())
  userId    String @unique
  
  // Overall stats
  totalPoints      Int @default(0)
  currentLevel     Int @default(1)
  experiencePoints Int @default(0)
  
  // Task stats
  tasksCompleted   Int @default(0)
  tasksCreated     Int @default(0)
  totalTaskTime    Int @default(0) // minutes
  
  // Event stats
  eventsAttended   Int @default(0)
  eventsCreated    Int @default(0)
  
  // Streak stats
  longestStreak    Int @default(0)
  currentStreak    Int @default(0)
  
  // Achievement stats
  achievementsUnlocked Int @default(0)
  badgesEarned     Int @default(0)
  
  // Time-based stats
  lastActiveDate   DateTime @default(now())
  joinDate         DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}

model Badge {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "first_task", "streak_7", "budget_master", etc.
  title       String
  description String
  icon        String?  // Icon name or URL
  rarity      String   @default("common") // "common", "rare", "epic", "legendary"
  earnedAt    DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("badges")
}

model Point {
  id          String   @id @default(cuid())
  userId      String
  amount      Int      // Can be positive or negative
  source      String   // "task_completion", "streak_bonus", "achievement", etc.
  description String?
  metadata    String?  // JSON string for additional data
  earnedAt    DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("points")
}

// Energy Engine Models
model EnergyPoint {
  id          String   @id @default(cuid())
  userId      String
  amount      Int      // EP earned (always positive)
  source      String   // "task_completion", "challenge_completion", "achievement", "event_completion"
  domain      String?  // "body", "mind", "social", "order", "finance", "outdoors", "rest"
  description String?
  metadata    String?  // JSON string for additional data
  earnedAt    DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("energy_points")
}

model DailyChallenge {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  domain      String   // "body", "mind", "social", "order", "finance", "outdoors", "rest"
  type        String   // "core" or "stretch"
  target      String   // What needs to be completed
  epReward    Int      // EP to be awarded
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  date        DateTime @default(now()) // Date the challenge is for
  metadata    String?  // JSON string for additional data
  requiredMinutes Int? // Duration for timed challenges
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions ChallengeSession[]

  @@map("daily_challenges")
}

model ChallengeSession {
  id              String   @id @default(cuid())
  userId          String
  challengeId     String
  startedAt       DateTime @default(now())
  pausedAt        DateTime?
  resumedAt       DateTime?
  completedAt     DateTime?
  elapsedSeconds  Int      @default(0)
  status          String   @default("IN_PROGRESS") // "IN_PROGRESS", "PAUSED", "COMPLETED", "ABANDONED"
  partialCredit   Boolean  @default(false)
  
  challenge DailyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("challenge_sessions")
}

model EnergyConversion {
  id            String   @id @default(cuid())
  userId        String
  epEarned      Int      // Total EP earned that day
  energyGained  Int      // Energy gained from conversion (0-100)
  conversionRate Float   // Rate used for conversion
  date          DateTime @default(now())
  metadata      String?  // JSON string for conversion details
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("energy_conversions")
}

model EnergyEmblem {
  id          String   @id @default(cuid())
  userId      String
  emblemType  String   // "bolt", "heart", "comet", "wave"
  isUnlocked  Boolean  @default(false)
  unlockedAt  DateTime?
  isActive    Boolean  @default(false)
  metadata    String?  // JSON string for emblem data
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("energy_emblems")
}

model UserEnergyProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  currentEnergy     Int      @default(50) // 0-100 scale
  energyLevel       Int      @default(5)  // 1-10 scale (legacy)
  epToday           Int      @default(0)  // EP accumulated today
  domainWeights     String?  // JSON object with domain weights
  personalizationData String? // JSON object for personalization
  lastConversion    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_energy_profiles")
}

// Enums removed for SQLite compatibility - using String types instead

// Resource Management Models
model ResourceSet {
  id                 String   @id @default(cuid())
  taskId             String?  @unique // Optional - can be associated with tasks
  eventId            String?  @unique // Optional - can be associated with events
  selectedResourceId String?  // ID of the currently selected resource
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  // Relations
  task               Task?      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  event              Event?     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  resources          Resource[]
  decisionLogs       DecisionLog[]
  
  @@map("resource_sets")
}

model Resource {
  id            String   @id @default(cuid())
  resourceSetId String
  kind          String   // 'url'|'image'|'file'|'note'
  urlOrKey      String?  // URL or storage key
  title         String?
  previewImage  String?  // URL to thumbnail/preview
  domain        String?  // normalized host for filter/search
  merchant      String?  // merchant/store name
  priceCents    Int?     // price in cents
  note          String?  // user notes
  tags          String   @default("[]") // JSON array of tags
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdById   String   // User who created this resource
  isSelected    Boolean  @default(false) // denormalized for fast queries
  
  // Relations
  resourceSet   ResourceSet @relation(fields: [resourceSetId], references: [id], onDelete: Cascade)
  createdBy     User        @relation(fields: [createdById], references: [id], onDelete: Cascade)
  
  @@map("resources")
}

model DecisionLog {
  id                 String   @id @default(cuid())
  resourceSetId      String
  selectedResourceId String
  changedAt          DateTime @default(now())
  reason             String?  // Optional reason for the change
  
  // Relations
  resourceSet        ResourceSet @relation(fields: [resourceSetId], references: [id], onDelete: Cascade)
  
  @@map("decision_logs")
}

// Feature Flags (per-user toggles for controlled rollouts)
model UserFeatureFlags {
  id     String @id @default(cuid())
  userId String @unique
  
  // AI Features
  askAI              Boolean @default(false)
  
  // Productivity Features
  focusLock          Boolean @default(false)
  mic                Boolean @default(false)
  priorityHierarchy  Boolean @default(false)
  templates          Boolean @default(false)
  pinnedEvents       Boolean @default(false)
  
  // Calendar Integrations
  googleCalendar     Boolean @default(false)
  outlookCalendar    Boolean @default(false)
  appleCalendar      Boolean @default(false)
  
  // Social Features
  friends            Boolean @default(true)
  
  // Marketplace
  shareScript        Boolean @default(true)
  
  // Energy & Gamification
  energyHUD          Boolean @default(false)
  energyGraph        Boolean @default(false)
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("user_feature_flags")
}

// Analytics Events (canonical event tracking)
model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String
  eventType String   // task_create, task_complete, suggestion_shown, etc.
  eventData String   // JSON blob with event-specific data
  metadata  String?  // JSON blob with context (UA, viewport, flags, etc.)
  createdAt DateTime @default(now())
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, eventType, createdAt])
  @@map("analytics_events")
}

// Audit Log (admin action tracking)
model AuditLog {
  id          String   @id @default(cuid())
  userId      String   // Admin who performed the action
  action      String   // Action type (e.g., "flag_override", "user_delete")
  targetType  String   // Type of entity affected (e.g., "user", "task")
  targetId    String   // ID of affected entity
  beforeState String?  // JSON snapshot before change
  afterState  String?  // JSON snapshot after change
  reason      String?  // Why the action was taken
  ipAddress   String?  // IP of admin
  createdAt   DateTime @default(now())
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, action, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

model Script {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  category    String?
  
  status      String   @default("DRAFT")
  version     Int      @default(1)
  isPublic    Boolean  @default(false)
  
  timesApplied Int     @default(0)
  lastApplied  DateTime?
  
  manifest    String
  variables   String?
  containsPII Boolean  @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications ScriptApplication[]
  catalogEntry TemplateCatalog?

  @@map("scripts")
}

model ScriptApplication {
  id              String   @id @default(cuid())
  scriptId        String
  userId          String
  eventId         String   @unique
  scriptVersion   Int
  
  status          String   @default("PROPOSED")
  appliedAt       DateTime @default(now())
  confirmedAt     DateTime?
  
  variableValues  String?
  generatedTasks  String?
  generatedEvents String?
  
  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("script_applications")
}

// Phase 3 - External Calendar Sync

model ExternalCalendarAccount {
  id          String   @id @default(cuid())
  userId      String
  provider    String   // "google", "outlook", "apple"
  accountId   String   // Provider's account ID
  email       String?
  
  // OAuth tokens
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?
  scopes       String? // JSON array of granted scopes
  
  // Sync state
  status       String   @default("CONNECTED") // "CONNECTED", "DISCONNECTED", "ERROR"
  syncToken    String?  // For delta sync
  lastSyncAt   DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  links ExternalCalendarLink[]

  @@unique([userId, provider, accountId])
  @@map("external_calendar_accounts")
}

model ExternalCalendarLink {
  id          String   @id @default(cuid())
  accountId   String
  
  // Provider event identification
  provider          String
  calendarId        String
  providerEventId   String
  seriesMasterId    String? // For recurring events
  recurrenceId      String? // For specific instances
  etag              String? // For conflict detection
  clientEventKey    String  // Hash for idempotency
  
  // Our canonical event
  canonicalEventId  String
  
  // Sync metadata
  lastSyncedAt      DateTime?
  syncDirection     String   @default("TWO_WAY") // "TO_PROVIDER", "FROM_PROVIDER", "TWO_WAY"
  
  // Conflict resolution
  lastMutator       String? // "user" or "provider"
  version           Int      @default(1)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  account ExternalCalendarAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([provider, calendarId, providerEventId])
  @@index([canonicalEventId])
  @@index([clientEventKey])
  @@map("external_calendar_links")
}

// ============================================================
// Phase 4: Friends & Social
// ============================================================

model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  addresseeId String
  status      String   // 'pending' | 'accepted' | 'blocked'
  
  // Metadata
  message     String?  // Optional message with request
  blockedBy   String?  // 'requester' | 'addressee' (who initiated the block)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  requester User @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("Addressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  
  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@index([status])
  @@map("friendships")
}

model FriendPrefs {
  userId            String  @id
  showFriends       Boolean @default(true)   // Show friends list
  showFriendEmblems Boolean @default(false)  // Show friend emblems (conservative default)
  showFriendEnergy  Boolean @default(false)  // Show friend energy levels (conservative default)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("friend_prefs")
}

model PrivacySetting {
  userId         String   @id
  hideMyEmblems  Boolean  @default(false) // Hide emblems from everyone
  hideLastActive Boolean  @default(false) // Hide last active timestamp
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user               User @relation(fields: [userId], references: [id], onDelete: Cascade)
  energyHiddenFrom   EnergyHiddenFrom[]
  
  @@map("privacy_settings")
}

model EnergyHiddenFrom {
  id               String @id @default(cuid())
  privacySettingId String
  hiddenFromUserId String
  
  createdAt DateTime @default(now())
  
  privacySetting PrivacySetting @relation(fields: [privacySettingId], references: [userId], onDelete: Cascade)
  
  @@unique([privacySettingId, hiddenFromUserId])
  @@index([privacySettingId])
  @@index([hiddenFromUserId])
  @@map("energy_hidden_from")
}

// ============================================================
// Phase 5: Template Gallery & Recommendations
// ============================================================

model TemplateCatalog {
  versionId String   @id // FK to Script.id (we use Script as TemplateVersion)
  tags      String   // JSON array of normalized tags
  category  String   // 'Move', 'Event', 'Launch', 'Wedding', etc.
  locale    String   @default("en-US")
  quality   Int      @default(0) // 0-100 curator score
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  script Script @relation(fields: [versionId], references: [id], onDelete: Cascade)
  
  @@index([category])
  @@index([quality])
  @@map("template_catalog")
}

model TemplateStats {
  versionId   String   @id
  applyCount  Int      @default(0)
  lastApplied DateTime?
  
  updatedAt DateTime @updatedAt
  
  @@map("template_stats")
}

model RecommendationLog {
  id        String   @id @default(cuid())
  userId    String
  eventId   String?
  versionId String
  position  Int      // 1, 2, or 3
  clicked   Boolean  @default(false)
  applied   Boolean  @default(false)
  reason    String?  // Why this was recommended
  
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([eventId])
  @@index([versionId])
  @@index([createdAt])
  @@map("recommendation_logs")
}

// ============================================================
// Phase 6: ShareScript Collaboration
// ============================================================

model Project {
  id             String    @id @default(cuid())
  name           String
  description    String?
  ownerId        String
  privacyDefault String    @default("project") // 'project' | 'restricted'
  archivedAt     DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  owner   User @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members ProjectMember[]
  items   ProjectItem[]
  audits  ProjectAuditLog[]
  resourceFolders ProjectResourceFolder[]
  resources ProjectResource[]
  
  @@index([ownerId])
  @@index([archivedAt])
  @@map("projects")
}

model ProjectMember {
  projectId String
  userId    String
  role      String  // 'owner' | 'admin' | 'editor' | 'contributor' | 'viewer'
  
  invitedAt  DateTime  @default(now())
  acceptedAt DateTime?
  invitedBy  String?
  
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("ProjectMemberships", fields: [userId], references: [id], onDelete: Cascade)
  
  @@id([projectId, userId])
  @@index([userId])
  @@index([role])
  @@map("project_members")
}

model ProjectItem {
  projectId String
  itemId    String
  itemType  String  // 'event' | 'task'
  privacy   String  @default("project") // 'project' | 'restricted'
  
  addedAt DateTime @default(now())
  addedBy String?
  
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@id([projectId, itemId])
  @@index([itemId])
  @@index([itemType])
  @@index([privacy])
  @@map("project_items")
}

model Assignment {
  itemId   String
  itemType String  // 'event' | 'task'
  userId   String
  role     String  // 'owner' | 'assignee' | 'watcher'
  
  assignedAt DateTime @default(now())
  assignedBy String?
  
  user User @relation("Assignments", fields: [userId], references: [id], onDelete: Cascade)
  
  @@id([itemId, userId])
  @@index([userId])
  @@index([itemId])
  @@map("assignments")
}

model ProjectAuditLog {
  id        String   @id @default(cuid())
  projectId String
  itemId    String?
  actorId   String
  action    String
  before    String?  // JSON
  after     String?  // JSON
  
  createdAt DateTime @default(now())
  
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@index([itemId])
  @@index([actorId])
  @@index([createdAt])
  @@map("project_audit_logs")
}

model Provenance {
  itemId     String @id
  itemType   String // 'event' | 'task'
  sourceType String // 'template' | 'promotion' | 'import' | 'fork'
  sourceRef  String // versionId, parentTaskId, calendarEventId, etc.
  details    String // JSON
  
  createdAt DateTime @default(now())
  
  @@index([itemId])
  @@map("provenance")
}

// User's saved scripts (created from events)
model UserScript {
  id          String   @id @default(cuid())
  userId      String
  sourceEventId String? // Original event this was created from
  
  // Script content
  title       String
  description String?
  category    String?  // 'Move', 'Wedding', 'Launch', etc.
  tags        String   @default("[]") // JSON array
  manifest    String   // JSON: { tasks: [...], subEvents: [...] }
  
  // Metadata
  isFavorite  Boolean  @default(false)
  applyCount  Int      @default(0) // How many times user has applied this
  lastUsedAt  DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([isFavorite])
  @@map("user_scripts")
}

model ProjectResourceFolder {
  id        String   @id @default(cuid())
  projectId String
  name      String   @default("Project Resources")
  description String?
  
  // Folder organization
  parentFolderId String? // For nested folders
  order          Int     @default(0)
  
  // Access control
  visibility String @default("project") // 'project' | 'restricted'
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  project        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentFolder   ProjectResourceFolder? @relation("FolderHierarchy", fields: [parentFolderId], references: [id], onDelete: SetNull)
  subfolders     ProjectResourceFolder[] @relation("FolderHierarchy")
  resources      ProjectResource[]
  
  @@index([projectId])
  @@index([parentFolderId])
  @@map("project_resource_folders")
}

model ProjectResource {
  id                String   @id @default(cuid())
  projectId         String
  folderId          String?  // Optional - can be in root or specific folder
  originalResourceId String? // Link to original task/event resource
  
  // Resource details (copied from original resource)
  kind          String   // 'url'|'image'|'file'|'note'
  urlOrKey      String?  // URL or storage key
  title         String?
  previewImage  String?  // URL to thumbnail/preview
  domain        String?  // normalized host for filter/search
  merchant      String?  // merchant/store name
  priceCents    Int?     // price in cents
  note          String?  // user notes
  tags          String   @default("[]") // JSON array of tags
  
  // Source tracking
  sourceTaskId  String?  // Which task this resource came from
  sourceEventId String?  // Which event this resource came from
  addedBy       String   // User who added this to the project
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  project   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder    ProjectResourceFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  addedByUser User              @relation("ProjectResourcesAdded", fields: [addedBy], references: [id])
  
  @@index([projectId])
  @@index([folderId])
  @@index([sourceTaskId])
  @@index([sourceEventId])
  @@map("project_resources")
}

// ============================================================
// BRIEF SYSTEM MODELS
// ============================================================

model BriefPreferences {
  id     String @id @default(cuid())
  userId String @unique
  
  // Timing
  morningBriefEnabled Boolean @default(true)
  morningBriefTime    String  @default("07:30") // HH:MM format
  eveningBriefEnabled Boolean @default(true)
  eveningBriefTime    String  @default("20:30")
  
  // Auto-popup settings
  autoPopMorning      Boolean @default(true)
  autoPopEvening      Boolean @default(false) // User must click "End Day"
  
  // Card preferences (weights 0-10)
  preferFirstBlock    Int @default(10)
  preferCriticalPrep  Int @default(9)
  preferConflicts     Int @default(10)
  preferPinned        Int @default(8)
  preferBudget        Int @default(7)
  preferWeather       Int @default(6)
  preferTemplates     Int @default(7)
  preferApprovals     Int @default(8)
  preferChallenges    Int @default(7)
  preferJournal       Int @default(8)
  
  // Display settings
  maxCards            Int @default(8)
  showInHeader        Boolean @default(true)
  emailDigest         Boolean @default(false)
  pushNotifications   Boolean @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("brief_preferences")
}

model BriefCard {
  id     String @id @default(cuid())
  userId String
  
  // Card metadata
  briefType    String   // "MORNING" | "EVENING"
  cardType     String   // "FIRST_BLOCK" | "CRITICAL_PREP" | "CONFLICTS" | etc.
  date         DateTime // Which day this brief is for
  
  // Scoring
  score        Float    // 0-100, determines order
  priority     Int      @default(5) // 1-10, tie-breaker
  
  // Display data
  title        String
  reason       String?  // One-line explanation
  keyFacts     String?  // JSON array of bullet points
  icon         String?  // Icon name
  color        String?  // Color scheme
  
  // Actions
  primaryAction   String   // JSON object { label, endpoint, method, payload }
  secondaryActions String? // JSON array of action objects
  deepLink        String?  // URL to relevant page
  
  // Lifecycle
  ttl          DateTime? // Auto-dismiss after this time
  dismissed    Boolean  @default(false)
  dismissedAt  DateTime?
  actionTaken  Boolean  @default(false)
  actionTakenAt DateTime?
  
  // Context (JSON)
  metadata     String?  // Any additional data for this card
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, briefType, date])
  @@index([userId, dismissed, date])
  @@map("brief_cards")
}

model JournalEntry {
  id     String @id @default(cuid())
  userId String
  date   DateTime // Date this entry is for
  
  // Reflection data
  highlights String? // JSON array of "went well" items
  lowlights  String? // JSON array of "could improve" items
  blockers   String? // JSON array of blockers
  freeformNote String? // Optional free-text journal
  
  // Completion stats
  tasksCompleted    Int? // Tasks done today
  tasksPlanned      Int? // Tasks that were planned
  eventsAttended    Int? // Events completed
  focusMinutes      Int? // Time in Focus Lock
  energyPointsEarned Int? // EP earned today
  
  // Next day planning
  tomorrowPriorities String? // JSON array of priorities set for tomorrow
  tomorrowFirstBlock String? // Suggested first block for tomorrow
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, date])
  @@index([userId, date])
  @@map("journal_entries")
}

// ============================================================
// EXPORT SYSTEM MODELS
// ============================================================

model ExportJob {
  id              String   @id @default(cuid())
  userId          String
  exportType      String   // 'pdf', 'docx', 'pptx', 'csv', 'xlsx', 'ics', 'html', 'json'
  scope           String   // JSON: { type: 'project'|'event'|'script', id: string, range?: string }
  audiencePreset  String   // 'owner', 'team', 'vendor', 'attendee', 'personal'
  options         String   // JSON: redaction settings, privacy options, etc.
  
  // Status tracking
  status          String   @default("queued") // 'queued', 'processing', 'completed', 'failed'
  progress        Int      @default(0) // 0-100
  errorMessage    String?
  
  // Output
  downloadUrl     String?
  shareUrl        String?
  sharePasscode   String?
  expiresAt       DateTime?
  
  // Metadata
  estimatedSize   Int?     // bytes
  actualSize      Int?     // bytes
  sections        String?  // JSON array of included sections
  redactions       String?  // JSON array of applied redactions
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, status])
  @@index([status, createdAt])
  @@map("export_jobs")
}

model ExportTemplate {
  id              String   @id @default(cuid())
  userId          String?
  name            String
  description     String?
  
  // Template configuration
  exportType      String   // 'pdf', 'docx', 'pptx', etc.
  scope           String   // JSON: default scope settings
  audiencePreset  String   // default audience preset
  options         String   // JSON: default options
  
  // Template content
  templateData    String   // JSON: template-specific data (headers, footers, styles, etc.)
  
  // Sharing
  isPublic        Boolean  @default(false)
  isSystem        Boolean  @default(false) // System templates
  
  // Usage tracking
  usageCount       Int      @default(0)
  lastUsedAt       DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([isPublic])
  @@index([isSystem])
  @@map("export_templates")
}

model ExportAnalytics {
  id              String   @id @default(cuid())
  userId          String?
  exportJobId     String?
  
  // Event tracking
  eventType       String   // 'export_started', 'export_completed', 'export_downloaded', 'share_viewed', etc.
  eventData       String   // JSON: event-specific data
  
  // Context
  exportType      String?
  scope           String?  // JSON
  audiencePreset  String?
  
  // Metadata
  userAgent       String?
  ipAddress       String?
  referrer        String?
  
  createdAt       DateTime @default(now())
  
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, eventType])
  @@index([exportJobId])
  @@index([createdAt])
  @@map("export_analytics")
}

// Event System - Outbox Pattern for reliable event delivery
model Outbox {
  id            String   @id @default(cuid())
  eventId       String   @unique // UUID for the event
  eventType     String   // e.g., 'TaskCompleted', 'ScriptApplied', 'CalendarWriteRequested'
  aggregateType String   // e.g., 'Task', 'Script', 'Calendar'
  aggregateId   String   // ID of the aggregate that generated the event
  payload       String   // JSON: event data
  occurredAt    DateTime @default(now())
  attempts      Int      @default(0)
  status        String   @default("pending") // 'pending', 'delivered', 'failed', 'dead_letter'
  error         String?  // Error message if delivery failed
  nextRetryAt   DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Delivery tracking
  deliveries    EventDelivery[]
  
  @@index([status, nextRetryAt])
  @@index([eventType])
  @@index([aggregateType, aggregateId])
  @@map("outbox")
}

model EventDelivery {
  id          String   @id @default(cuid())
  eventId     String   // References Outbox.eventId
  target      String   // Target handler or service
  deliveredAt DateTime @default(now())
  success     Boolean
  error       String?  // Error message if delivery failed
  
  outbox      Outbox   @relation(fields: [eventId], references: [eventId], onDelete: Cascade)
  
  @@unique([eventId, target])
  @@index([deliveredAt])
  @@map("event_delivery")
}

// Idempotency Keys for safe retries
model IdempotencyKey {
  key           String   @id // The idempotency key
  scope         String   // e.g., 'calendar-write', 'script-apply', 'export-generate'
  requestHash   String   // Hash of the request to detect changes
  response      String   // JSON: cached response
  createdAt     DateTime @default(now())
  expiresAt     DateTime // When this key expires (e.g., 24 hours)
  
  @@index([scope])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

// Daily Energy Reset tracking
model UserEnergyDailySnapshot {
  id              String   @id @default(cuid())
  userId          String
  snapshotDate    DateTime // Date in user's local timezone
  energy          Int      // Energy level at snapshot time
  epToday         Int      // EP accumulated today
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, snapshotDate])
  @@index([snapshotDate])
  @@map("user_energy_daily_snapshots")
}

// Cron job locks for preventing concurrent execution
model CronLock {
  id          String   @id @default(cuid())
  jobName     String   @map("jobName")   // Name of the cron job
  lockedBy    String   @map("lockedBy")  // Who acquired the lock (trace ID or process ID)
  lockedAt    DateTime @map("lockedAt") @default(now())
  expiresAt   DateTime @map("expiresAt") // When the lock expires
  metadata    String?  @map("metadata")  // JSON: additional lock metadata

  @@index([jobName, expiresAt])
  @@index([expiresAt])
  @@map("cron_locks")
}

