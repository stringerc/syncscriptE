generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                @id @default(cuid())
  email                   String                @unique
  name                    String?
  password                String
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  emailVerified           Boolean?
  emailVerifiedAt         DateTime?
  passwordResetToken      String?
  passwordResetExpires    DateTime?
  timezone                String?
  energyLevel             Int?                  @default(5)
  emailVerificationToken  String?
  avatar                  String?
  emailVerificationExpiry DateTime?
  currentLocation         String?
  homeLocation            String?
  workLocation            String?
  achievements            Achievement[]
  calendarIntegrations    CalendarIntegration[]
  conversations           Conversation[]
  dailyEnergy             EnergyLevel[]
  events                  Event[]
  financialAccounts       FinancialAccount[]
  notifications           Notification[]
  streaks                 Streak[]
  tasks                   Task[]
  settings                UserSettings?

  @@map("users")
}

model UserSettings {
  id                    String  @id @default(cuid())
  userId                String  @unique
  emailNotifications    Boolean @default(true)
  pushNotifications     Boolean @default(true)
  smsNotifications      Boolean @default(false)
  aiSchedulingEnabled   Boolean @default(true)
  aiBudgetAdviceEnabled Boolean @default(true)
  aiEnergyAdaptation    Boolean @default(true)
  dataSharingEnabled    Boolean @default(false)
  workHoursStart        String  @default("09:00")
  workHoursEnd          String  @default("17:00")
  breakDuration         Int     @default(15)
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model EnergyLevel {
  id     String   @id @default(cuid())
  userId String
  level  Int
  date   DateTime @default(now())
  notes  String?
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("energy_levels")
}

model CalendarIntegration {
  id           String    @id @default(cuid())
  userId       String
  provider     String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("calendar_integrations")
}

model FinancialAccount {
  id          String   @id @default(cuid())
  userId      String
  plaidItemId String
  accountId   String
  accountName String
  accountType String
  balance     Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("financial_accounts")
}

model Task {
  id                String    @id @default(cuid())
  userId            String
  title             String
  description       String?
  priority          String    @default("MEDIUM")
  status            String    @default("PENDING")
  dueDate           DateTime?
  estimatedDuration Int?
  actualDuration    Int?
  energyRequired    Int?
  budgetImpact      Float?
  aiGenerated       Boolean   @default(false)
  extractedFrom     String?
  scheduledAt       DateTime?
  completedAt       DateTime?
  tags              String?
  eventId           String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  location          String?
  notes             String?
  deletedAt         DateTime?
  subtasks          Subtask[]
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  event             Event?    @relation(fields: [eventId], references: [id])

  @@map("tasks")
}

model Subtask {
  id        String  @id @default(cuid())
  taskId    String
  title     String
  completed Boolean @default(false)
  order     Int
  task      Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("subtasks")
}

model Event {
  id               String   @id @default(cuid())
  userId           String
  title            String
  description      String?
  startTime        DateTime
  endTime          DateTime
  location         String?
  isAllDay         Boolean  @default(false)
  calendarEventId  String?
  calendarProvider String?
  aiGenerated      Boolean  @default(false)
  budgetImpact     Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preparationTasks Task[]

  @@map("events")
}

model Conversation {
  id             String   @id @default(cuid())
  userId         String
  content        String
  source         String
  extractedTasks String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("conversations")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  actionUrl String?
  metadata  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String
  points      Int      @default(0)
  unlockedAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("achievements")
}

model Streak {
  id       String   @id @default(cuid())
  userId   String
  type     String
  count    Int      @default(0)
  lastDate DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}
