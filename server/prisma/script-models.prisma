// Script/Template Models for Phase 2
// Add these to the main schema.prisma file

model Script {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  category    String? // "work", "personal", "health", etc.
  
  // Script metadata
  status      String   @default("DRAFT") // "DRAFT", "PUBLISHED", "ARCHIVED"
  version     Int      @default(1)
  isPublic    Boolean  @default(false)
  
  // Statistics
  timesApplied Int     @default(0)
  lastApplied  DateTime?
  
  // Template data (JSON)
  manifest    String   // JSON: tasks, sub-events, offsets, durations, deps
  variables   String?  // JSON: variable definitions for apply-time substitution
  
  // Privacy
  containsPII Boolean  @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications ScriptApplication[]

  @@map("scripts")
}

model ScriptApplication {
  id              String   @id @default(cuid())
  scriptId        String
  userId          String
  eventId         String   @unique // One application per event (idempotent)
  scriptVersion   Int
  
  // Application metadata
  status          String   @default("PROPOSED") // "PROPOSED", "CONFIRMED", "ACTIVE"
  appliedAt       DateTime @default(now())
  confirmedAt     DateTime?
  
  // Variable values used
  variableValues  String?  // JSON: key-value pairs
  
  // Generated items
  generatedTasks  String?  // JSON: array of task IDs
  generatedEvents String?  // JSON: array of sub-event IDs
  
  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("script_applications")
}

