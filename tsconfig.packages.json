{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@syncscript/shared-kernel": ["./packages/shared-kernel/src"],
      "@syncscript/planning-core": ["./packages/planning-core/src"],
      "@syncscript/scripts": ["./packages/scripts/src"],
      "@syncscript/budgeting": ["./packages/budgeting/src"],
      "@syncscript/gamification": ["./packages/gamification/src"],
      "@syncscript/collab": ["./packages/collab/src"],
      "@syncscript/exports": ["./packages/exports/src"]
    }
  },
  "references": [
    {
      "path": "./packages/shared-kernel"
    },
    {
      "path": "./packages/planning-core"
    },
    {
      "path": "./packages/scripts"
    },
    {
      "path": "./packages/budgeting"
    },
    {
      "path": "./packages/gamification"
    },
    {
      "path": "./packages/collab"
    },
    {
      "path": "./packages/exports"
    }
  ],
  "include": [],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
